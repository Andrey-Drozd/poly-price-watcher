# Used by docker compose for local PostgreSQL
POSTGRES_DB=poly_price_watcher
POSTGRES_USER=poly_price_watcher
POSTGRES_PASSWORD=poly_price_watcher
POSTGRES_PORT=5434

# Profiles:
# local -> uses application-local.yml
# prod  -> expects the variables below
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8086
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5434/poly_price_watcher
SPRING_DATASOURCE_USERNAME=poly_price_watcher
SPRING_DATASOURCE_PASSWORD=poly_price_watcher

# Used mainly by the prod profile
POLYMARKET_WEBSOCKET_ENABLED=true
POLYMARKET_WEBSOCKET_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
POLYMARKET_WEBSOCKET_PING_INTERVAL=10s
POLYMARKET_WEBSOCKET_RECONNECT_DELAY=5s
POLYMARKET_WEBSOCKET_CUSTOM_FEATURE_ENABLED=true

# Tracked markets are configured in:
# src/main/resources/polymarket-markets.yml
